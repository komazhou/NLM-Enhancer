{
  "manifest_version": 3,
  "name": "NotebookLM++",
  "version": "1.0.0",
  "description": "为 NotebookLM 增加选中引用、公式复制、时间轴导航、提示词库等增强功能",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "clipboardWrite"
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://notebooklm.google.com/*"
      ],
      "js": [
        "src/utils/storage.js",
        "src/utils/dom.js",
        "src/features/quoteReply.js",
        "src/features/formulaCopy.js",
        "src/features/timeline.js",
        "src/features/export.js",
        "src/features/promptVault.js",
        "src/features/mermaidRender.js",
        "src/features/draftSave.js",
        "src/features/sendBehavior.js",
        "src/features/uiTweaks.js",
        "src/features/preventScroll.js",
        "src/features/deleteMessage.js",
        "src/features/timelineSearch.js",
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["lib/*"],
      "matches": ["https://notebooklm.google.com/*"]
    }
  ]
}
